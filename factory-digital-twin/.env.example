# Factory Digital Twin — environment template
# Copy to .env and fill secrets. .env is gitignored — never commit real values.
# This generator is mostly CLI-arg driven; these vars supply defaults for those flags.

# NATS endpoint for real-time event replay (run.py --nats / --realtime).
NATS_URL=nats://localhost:4222

# MinIO upload of synthetic defect images (synthetic-images/defect_generator.py).
# Defaults are demo creds — CHANGE for any non-local use.
MINIO_ACCESS_KEY=minioadmin         # secret — demo default; override in prod
MINIO_SECRET_KEY=minioadmin         # secret — demo default; override in prod
