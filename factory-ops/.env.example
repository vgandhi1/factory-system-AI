# FactoryOps AI Command Center — environment template
# Copy to .env and fill secrets. .env is gitignored — never commit real values.
# Every var below is read with a safe local default; only secrets are blank.

# ---- Python API (api/config.py) ----
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DB=factory
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=                # secret — blank for local dev, set in prod
# PostgreSQL RAG knowledge base. Default embeds local dev creds; override in prod.
POSTGRES_DSN=postgresql://factory:factory@localhost:5432/factory_kb
# Copilot. Without ANTHROPIC_API_KEY the copilot uses the deterministic fallback.
ANTHROPIC_API_KEY=                  # secret — enables the real Claude copilot
COPILOT_MODEL=claude-sonnet-4-6
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
DEFAULT_HORIZON_S=86400             # 24h OEE horizon (match the Digital Twin)

# ---- Go gateway (gateway/internal/config) ----
NATS_URL=nats://localhost:4222
CLICKHOUSE_ADDR=localhost:9000      # ClickHouse native protocol (not the HTTP port)
# CLICKHOUSE_DB / CLICKHOUSE_USER / CLICKHOUSE_PASSWORD shared with the API above.
GATEWAY_BATCH_SIZE=500
GATEWAY_FLUSH_MS=1000

# ---- Frontend (Next.js) ----
NEXT_PUBLIC_API_URL=http://localhost:8000
