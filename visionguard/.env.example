# VisionGuard AI Quality Inspection — environment template
# Copy to .env and fill secrets. .env is gitignored — never commit real values.

# ---- Inference server (inference-server/config.py) ----
MODEL_PATH=models/best.pt           # promoted custom model; falls back below if absent
FALLBACK_MODEL=yolov8n.pt
IMG_SIZE=640
CONF_THRES=0.25                     # YOLO box filter (min confidence to emit a box)
REVIEW_CONF_THRES=0.70              # human-review gate: below this -> never auto-accept
EMBED_DIM=256
POSTGRES_DSN=postgresql://visionguard:visionguard@localhost:5432/visionguard

# MinIO object store (part images). Defaults are demo creds — CHANGE for any non-local use.
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin         # secret — demo default; override in prod
MINIO_SECRET_KEY=minioadmin         # secret — demo default; override in prod
MINIO_SECURE=false

# ---- Model training / retraining (model-training, retraining-pipeline) ----
BASE_WEIGHTS=yolov8n.pt
# DATASET_DIR / BASE_DATA_YAML / DEPLOY_DIR default to repo-relative paths — set to override.
# DATASET_DIR=
# BASE_DATA_YAML=
# DEPLOY_DIR=
RETRAIN_EPOCHS=30
IMPROVE_MARGIN=0.005                # min mAP50 gain to promote a retrained model
